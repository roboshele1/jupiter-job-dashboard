          background: C.panel, borderRadius: 8, padding: "14px 16px",
          border: `1px solid ${projectionAt2037 >= goalTarget ? C.green + "40" : C.border}`,
        }}>
          <div style={{ ...mono, fontSize: 9, color: C.textMuted, letterSpacing: "0.1em", marginBottom: 8 }}>2037 PROJECTION</div>
          <div style={{
