// ── Helpers ──────────────────────────────────────────────────────────────────
function fmtMoney(n) {
  return "$" + Number(n || 0).toLocaleString(undefined, { minimumFractionDigits: 0, maximumFractionDigits: 0 });
}
function fmtPct(n, decimals = 1) {
  if (n === null || n === undefined) return "\u2014";
  const sign = Number(n) >= 0 ? "+" : "";
  return `${sign}${Number(n).toFixed(decimals)}%`;
}
function fmtCAGR(n) {
  if (n === null || n === undefined) return "\u2014";
  return `${Number(n).toFixed(1)}% / yr`;
}
function deltaColor(n) {
  if (Number(n) > 0) return C.green;
  if (Number(n) < 0) return C.red;
  return C.textMuted;
}

// Project a position value forward at a given CAGR
function projectValue(currentValue, cagrPct, years) {
  if (!currentValue || !years) return currentValue || 0;
  const r = (cagrPct || 0) / 100;
  return currentValue * Math.pow(1 + r, years);
}

// Project portfolio with monthly DCA contributions
function projectValueWithDCA(currentValue, monthlyDCA, cagrPct, months) {
  if (!months) return currentValue || 0;
  const monthlyRate = Math.pow(1 + cagrPct / 100, 1 / 12) - 1;
  let balance = currentValue || 0;
  
  for (let m = 0; m < months; m++) {
    balance = balance * (1 + monthlyRate) + monthlyDCA;
  }
  
  return balance;
}

// Calculate months to reach target given current value, monthly DCA, CAGR
function monthsToTarget(currentValue, monthlyDCA, cagrPct, target) {
  const monthlyRate = Math.pow(1 + cagrPct / 100, 1 / 12) - 1;
  let balance = currentValue || 0;
  let months = 0;
  const maxMonths = 600; // 50 year safety limit
  
  while (balance < target && months < maxMonths) {
    balance = balance * (1 + monthlyRate) + monthlyDCA;
    months++;
  }
  
  return months >= maxMonths ? null : months;
}

// Conviction CAGR assumptions (mirrors Kelly convictions)
const CAGR_ASSUMPTIONS = {
  NVDA: 28, ASML: 18, AVGO: 25, MSTR: 35,
  HOOD: 15, BMNR: 12, APLD: 10, NOW: 20,
  BTC:  40, ETH:  25,
};

