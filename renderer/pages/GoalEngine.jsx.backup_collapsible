// ── Compounding curve ─────────────────────────────────────────────────────────
function CompoundingCurve({ portfolioValue, requiredCAGR, goalTarget, goalYear, monthlyDCA }) {
  const years = goalYear - new Date().getFullYear();
  const steps = years * 4; // quarterly points

  const curve = useMemo(() => {
    if (!portfolioValue || !requiredCAGR) return [];
    const pts = [];
    const reqMonthly  = Math.pow(1 + requiredCAGR / 100, 1 / 12) - 1;
    // Conservative estimate: 60% of required CAGR
    const consMonthly = Math.pow(1 + (requiredCAGR * 0.6) / 100, 1 / 12) - 1;
    const totalMonths = years * 12;
    const interval    = Math.ceil(totalMonths / steps);

    let req  = portfolioValue;
    let cons = portfolioValue;

    for (let m = 0; m <= totalMonths; m += interval) {
      pts.push({ month: m, required: req, conservative: cons });
      for (let i = 0; i < interval; i++) {
        req  = req  * (1 + reqMonthly) + monthlyDCA;
        cons = cons * (1 + consMonthly) + monthlyDCA;
      }
    }
    return pts;
  }, [portfolioValue, requiredCAGR, years, steps, monthlyDCA]);

  if (!curve.length) return null;

  const W = 660, H = 200, PAD = { l: 60, r: 20, t: 16, b: 32 };
  const innerW = W - PAD.l - PAD.r;
  const innerH = H - PAD.t - PAD.b;
  const maxVal = Math.max(...curve.map(p => p.required), goalTarget);
  const totalMonths = years * 12;

  function xPos(m)  { return PAD.l + (m / totalMonths) * innerW; }
  function yPos(v)  { return PAD.t + innerH - (v / maxVal) * innerH; }

  const reqPath  = curve.map((p, i) => `${i === 0 ? "M" : "L"}${xPos(p.month).toFixed(1)},${yPos(p.required).toFixed(1)}`).join(" ");
  const consPath = curve.map((p, i) => `${i === 0 ? "M" : "L"}${xPos(p.month).toFixed(1)},${yPos(p.conservative).toFixed(1)}`).join(" ");
  const goalY    = yPos(goalTarget);

  // Year markers
  const yearMarkers = Array.from({ length: years + 1 }, (_, i) => i).map(yr => ({
    label: String(new Date().getFullYear() + yr),
    x: xPos(yr * 12),
  }));

  return (
    <div style={{ background: C.surface, border: `1px solid ${C.border}`, borderRadius: 10, padding: "20px 24px", marginBottom: 20 }}>
      <SectionLabel sub="Required CAGR trajectory vs conservative (60%) scenario">Compounding Curve to {goalYear}</SectionLabel>

      <svg width="100%" viewBox={`0 0 ${W} ${H}`} style={{ overflow: "hidden" }}>
        {/* Goal line */}
        <line x1={PAD.l} y1={goalY} x2={W - PAD.r} y2={goalY}
          stroke={C.green} strokeWidth="1" strokeDasharray="4,3" opacity="0.5" />
        <text x={PAD.l + 8} y={goalY + 4} style={{ ...mono, fontSize: 9, fill: C.green, fontFamily: "'IBM Plex Mono', monospace" }}>{fmtMoney(goalTarget)}</text>

        {/* Conservative path */}
        <path d={consPath} fill="none" stroke={C.blue} strokeWidth="1.5" opacity="0.5" strokeDasharray="3,2" />

        {/* Required path */}
        <path d={reqPath} fill="none" stroke={C.gold} strokeWidth="2" />

        {/* Current value dot */}
        <circle cx={xPos(0)} cy={yPos(portfolioValue)} r="4" fill={C.gold} />

        {/* Year labels */}
        {yearMarkers.map(m => (
          <text key={m.label} x={m.x} y={H - 4}
            textAnchor="middle"
            style={{ ...mono, fontSize: 8, fill: C.textMuted, fontFamily: "'IBM Plex Mono', monospace" }}>
            {m.label}
          </text>
        ))}

        {/* Y axis: current + goal */}
        <text x={PAD.l - 4} y={yPos(portfolioValue) + 4}
          textAnchor="end"
          style={{ ...mono, fontSize: 8, fill: C.textSec, fontFamily: "'IBM Plex Mono', monospace" }}>
          {fmtMoney(portfolioValue)}
        </text>
      </svg>

      <div style={{ display: "flex", gap: 20, marginTop: 8 }}>
        <div style={{ display: "flex", alignItems: "center", gap: 6 }}>
          <div style={{ width: 20, height: 2, background: C.gold }} />
          <span style={{ ...mono, fontSize: 10, color: C.textMuted }}>Required ({fmtCAGR(requiredCAGR)})</span>
        </div>
        <div style={{ display: "flex", alignItems: "center", gap: 6 }}>
          <div style={{ width: 20, height: 2, background: C.blue, opacity: 0.6 }} />
          <span style={{ ...mono, fontSize: 10, color: C.textMuted }}>Conservative ({fmtCAGR(requiredCAGR * 0.6)})</span>
        </div>
      </div>
    </div>
  );
}

// ── DCA SENSITIVITY CALCULATOR [NEW] ──────────────────────────────────────────
function DCASensitivityCalculator({ portfolioValue, requiredCAGR, goalTarget, goalYear, baselineDCA }) {
  const [sliderDCA, setSliderDCA] = useState(baselineDCA || 500);
  
  const yearsRemaining = goalYear - new Date().getFullYear();
  const monthsRemaining = yearsRemaining * 12;
  
  // Calculate projection at adjusted DCA
  const projectionAt2037 = useMemo(() => {
    return projectValueWithDCA(portfolioValue, sliderDCA, requiredCAGR, monthsRemaining);
  }, [portfolioValue, sliderDCA, requiredCAGR, monthsRemaining]);
  
  // Calculate months to reach goal at adjusted DCA
  const monthsToGoal = useMemo(() => {
    return monthsToTarget(portfolioValue, sliderDCA, requiredCAGR, goalTarget);
  }, [portfolioValue, sliderDCA, requiredCAGR, goalTarget]);
  
  const yearsToGoal = monthsToGoal ? monthsToGoal / 12 : null;
  
  // Calculate increase vs baseline
  const dcaDelta = sliderDCA - baselineDCA;
  const dcaDeltaPct = baselineDCA > 0 ? (dcaDelta / baselineDCA) * 100 : 0;

  const handleSliderChange = (e) => {
    const val = Number(e.target.value);
    setSliderDCA(Math.max(0, val));
  };

  const handleInputChange = (e) => {
    const val = Number(e.target.value);
    setSliderDCA(Math.max(0, isNaN(val) ? 0 : val));
  };

  return (
    <div style={{ background: C.surface, border: `1px solid ${C.border}`, borderRadius: 10, padding: "22px 24px", marginBottom: 20 }}>
      <SectionLabel sub="Adjust monthly DCA and see real-time impact on 2037 projections">DCA Sensitivity Calculator</SectionLabel>

      {/* Slider + Input */}
      <div style={{ marginBottom: 24 }}>
        <div style={{ display: "flex", justifyContent: "space-between", alignItems: "center", marginBottom: 10 }}>
          <label style={{ ...mono, fontSize: 11, color: C.textMuted, letterSpacing: "0.1em", fontWeight: 700 }}>
            MONTHLY DCA
          </label>
          <div style={{ display: "flex", alignItems: "center", gap: 8 }}>
            <span style={{ ...mono, fontSize: 12, color: C.textMuted }}>$</span>
            <input
              type="number"
              value={sliderDCA}
              onChange={handleInputChange}
              style={{
                fontFamily: "'IBM Plex Mono', monospace",
                width: 100,
                padding: "6px 8px",
                fontSize: 13,
                fontWeight: 600,
                background: C.panel,
                border: `1px solid ${C.border}`,
                borderRadius: 6,
                color: C.text,
                textAlign: "right",
              }}
              min="0"
              step="50"
            />
            <span style={{ ...mono, fontSize: 11, color: C.textMuted }}>/mo</span>
          </div>
        </div>

        {/* Range slider */}
        <input
          type="range"
          min="0"
          max={Math.max(sliderDCA * 2, 10000)}
          value={sliderDCA}
          onChange={handleSliderChange}
          style={{
            width: "100%",
            height: 6,
            borderRadius: 3,
            background: C.panel,
            outline: "none",
            WebkitAppearance: "none",
            appearance: "none",
            cursor: "pointer",
          }}
        />
        <style>{`
          input[type="range"]::-webkit-slider-thumb {
            appearance: none;
            width: 16px;
            height: 16px;
            borderRadius: 50%;
            background: ${C.blue};
            cursor: pointer;
            boxShadow: 0 0 8px ${C.blue}80;
          }
          input[type="range"]::-moz-range-thumb {
            width: 16px;
            height: 16px;
            borderRadius: 50%;
            background: ${C.blue};
            cursor: pointer;
            border: none;
            boxShadow: 0 0 8px ${C.blue}80;
          }
          input[type="range"]::-webkit-slider-runnable-track {
            background: linear-gradient(90deg, ${C.blue}40, ${C.cyan}40);
            height: 6px;
            borderRadius: 3px;
          }
          input[type="range"]::-moz-range-track {
            background: transparent;
            border: none;
          }
