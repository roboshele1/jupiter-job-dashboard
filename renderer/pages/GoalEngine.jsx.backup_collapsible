          <span style={{ ...mono, fontSize: 9, color: C.textMuted }}>Max: {fmtMoney(Math.max(sliderDCA * 2, 10000))}</span>
        </div>
      </div>

      {/* Output cards */}
      <div style={{ display: "grid", gridTemplateColumns: "repeat(2, 1fr)", gap: 8 }}>
        {/* 2037 Projection */}
