{
  "name": "jupiter",
  "version": "1.0.0",
  "private": true,
  "main": "electron/main.js",
  "description": "JUPITER — Institutional-grade portfolio intelligence desktop application",
  "author": "Edwin Theadoos Akosua Adoo",
  "scripts": {
    "dev": "vite",
    "electron": "electron .",
    "start": "concurrently \"npm run dev\" \"npm run electron\"",
    "build:renderer": "vite build",
    "build:desktop": "npm run build:renderer && electron-builder --mac"
  },
  "dependencies": {
    "axios": "^1.13.2",
    "cors": "^2.8.5",
    "dotenv": "^17.2.3",
    "express": "^5.2.1",
    "node-fetch": "^2.7.0",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "react-router-dom": "^7.10.1",
    "react-sparklines": "^1.7.0",
    "uuid": "^13.0.0",
    "zustand": "^5.0.9"
  },
  "devDependencies": {
    "@vitejs/plugin-react": "^4.2.0",
    "concurrently": "^8.2.0",
    "electron": "^39.2.7",
    "electron-builder": "^26.4.0",
    "vite": "^7.2.7"
  },
  "build": {
    "appId": "com.jupiter.desktop",
    "productName": "Jupiter",
    "directories": {
      "output": "dist-desktop"
    },
    "files": [
      "electron/**/*",
      "renderer/dist/**/*",
      "package.json"
    ],
    "asar": true,
    "mac": {
      "category": "public.app-category.finance",
      "target": [
        "dmg"
      ],
      "icon": "assets/icon.icns"
    }
  }
}
